<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Explizite Sichtbarkeits-Erklaerung: ohne das koennen ab Android 11
         manche Apps in der Abfrage fehlen, selbst wenn Minimal Launcher als
         Standard-Startbildschirm gesetzt ist. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:label="GHOSTS Launcher"
        android:theme="@style/Theme.MinimalLauncher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.MinimalLauncher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".SettingsActivity" android:exported="false" />
        <activity android:name=".FavoritesPickerActivity" android:exported="false" />
        <activity android:name=".AppVisibilityActivity" android:exported="false" />
        <activity android:name=".AppRenameActivity" android:exported="false" />
        <activity android:name=".DockPickerActivity" android:exported="false" />
        <activity android:name=".TimeLimitAppsActivity" android:exported="false" />
        <activity android:name=".ModeManagerActivity" android:exported="false" />
        <activity android:name=".ModeEditActivity" android:exported="false" />
        <activity android:name=".ModeLockActivity" android:exported="false" />
        <activity android:name=".ModeNotificationMuteActivity" android:exported="false" />

        <receiver android:name=".TimeLimitReceiver" android:exported="false" />

        <service android:name=".CountdownOverlayService" android:exported="false" />

        <service
            android:name=".MuteNotificationListenerService"
            android:label="Minimal Launcher Modus-Stummschaltung"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="false">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>
</manifest>
