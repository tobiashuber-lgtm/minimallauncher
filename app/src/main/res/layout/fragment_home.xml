<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="46sp"
            android:fontFamily="monospace"
            android:text="00:00" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:text="" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.minimal.launcher.DottedBatteryView
                android:id="@+id/batteryFill"
                android:layout_width="0dp"
                android:layout_height="14dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="#999999"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="--%" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutFavorites"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="14dp">

            <ImageView
                android:id="@+id/dockPhone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/sym_action_call"
                android:tint="#FFFFFF"
                android:contentDescription="Telefon" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/dockCamera"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="18dp"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="#FFFFFF"
                android:contentDescription="Kamera" />

            <ImageView
                android:id="@+id/dockMessage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="18dp"
                android:src="@android:drawable/ic_menu_send"
                android:tint="#FFFFFF"
                android:contentDescription="Nachrichten" />

            <ImageView
                android:id="@+id/dockMail"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="#FFFFFF"
                android:contentDescription="Mail" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
